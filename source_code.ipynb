import gradio as gr

def gradio_wrapper(message, history):
    """
    message: The current string the user typed.
    history: A list of previous turns (Gradio manages this automatically).
    """
    try:
        # Call your existing agent logic
        # If your agent_loop requires history, you can pass it here
        response = agent_loop(message)
        return response
    except Exception as e:
        return f"⚠️ Error: {str(e)}"

# Define the Look and Feel
demo = gr.ChatInterface(
    fn=gradio_wrapper,
    title="🌍 Travel Concierge AI",
    description="Ask me about flights, hotels, or travel plans!",
    theme="soft", # Options: "soft", "glass", "monochrome", or "default"
    examples=[
        "What are the flights from Bengaluru to Bhubaneswar?",
        "Suggest some hotels in Mumbai",
        "Plan a 3-day trip to Goa"
    ],
    cache_examples=False,
)

if __name__ == "__main__":
    # use share=True if you want a public link to send to friends
    demo.launch(debug=True, share=False)